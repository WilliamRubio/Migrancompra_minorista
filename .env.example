# Puerto del servidor (Railway/Render lo inyecta automáticamente)
PORT=3000

# Entorno: "production" activa cookies seguras y trust proxy
NODE_ENV=development

# Cadena de conexión PostgreSQL (Railway la crea al agregar plugin de PostgreSQL)
# Ejemplo: postgresql://user:password@host:5432/railway
# Requerida en producción.
DATABASE_URL=
